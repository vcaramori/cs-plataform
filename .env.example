# ==============================================================================
# CS-CONTINUUM — ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# INSTRUCOES:
#   1. Copie este arquivo para .env
#   2. Substitua cada placeholder pelo valor real da sua chave
#   3. NUNCA commite o arquivo .env real no git
# ==============================================================================

# ── ENCRYPTION_KEY (chave-mestra — OPCIONAL) ──────────────────────────────────
# Cifra (AES-256-GCM) os segredos do banco (tokens OAuth Read.ai/Microsoft, chaves LLM).
# NÃO é mais obrigatória em env: a chave é AUTO-PROVISIONADA no banco
# (app_settings.encryption_key) — config 100% no banco, conforme a premissa do projeto.
# Se você definir aqui (hex de 64 chars), ela é ADOTADA no banco na 1ª vez (útil para
# migrar uma instalação antiga). Gere com: openssl rand -hex 32
# ENCRYPTION_KEY=your-64-char-hex-key

# ── Supabase (Banco Relacional + Auth) ────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# ── Google Gemini API (Principal) ─────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Configurações de Modelos (Modo Estabilizado)
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-pro-latest
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_EMBEDDING_DIMENSIONS=768

# ── LLM Gateway (Configuração de Roteamento) ──────────────────────────────────
# Atualmente configurado para modo 'gemini' exclusivo para estabilização
LLM_PROVIDER=gemini
LLM_TIMEOUT_MS=120000
LLM_ALLOW_FALLBACK=false
LLM_FALLBACK_PROVIDER=none

# ── Anthropic Claude (Fallback Futuro) ────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_MAX_TOKENS=1024

# ── Configurações de Negócio / RAG ─────────────────────────────────────────────
CHUNK_SIZE=4000
CHUNK_OVERLAP=500
VECTOR_TOP_K=15
SENTIMENT_ALERT_THRESHOLD=-0.4
COST_TO_SERVE_WARN=0.15
COST_TO_SERVE_CRITICAL=0.30

# ── Integrações (Opcional) ────────────────────────────────────────────────────
AIRTABLE_TOKEN=your-airtable-token
# Segredo dos crons (HelpDesk/Read.ai): NÃO é mais necessário em env. Os crons são
# agendados no Supabase (pg_cron) e o segredo fica no banco (app_settings.helpdesk_integration.secret),
# editável em Configurações → HelpDesk. API_SECRET segue só como fallback opcional.
API_SECRET=your-internal-api-secret
SYNC_INTERVAL_MINUTES=5

# MCP da ferramenta (servidor de tools para agentes).
# MCP_API_TOKEN: segredo do endpoint /api/mcp (use o mesmo no .mcp.json do agente).
# MCP_ACTOR_USER_ID: UUID de um usuário REAL (auth.users) p/ atribuir lançamentos
#   feitos pelo agente (esforço/interações). MCP_HTTP_URL é só para a ponte stdio.
MCP_API_TOKEN=
MCP_ENABLED=true
MCP_ACTOR_USER_ID=
MCP_HTTP_URL=http://localhost:3000/api/mcp

# PSA — apontamento de horas de implantação (Edge Function teams-bot).
# LIGADO por padrão: todo esforço de onboarding é enviado automaticamente.
# A URL já tem default embutido (server-only). Sobrescreva só se mudar de endpoint.
# Para DESLIGAR a integração: PSA_SYNC_ENABLED=false
PSA_TEAMS_BOT_URL=
PSA_INTEGRATION_TOKEN=
PSA_SYNC_ENABLED=true
PSA_TIMEOUT_MS=10000

# Habilita os endpoints de migration (/api/migrations/*) que executam SQL
# arbitrário. Mantenha desligado em produção; prefira `supabase db push`.
ENABLE_MIGRATION_ENDPOINT=false
# Pula a validação de envs obrigatórias (use só em etapas de build sem credenciais).
SKIP_ENV_VALIDATION=false

# ── Suporte / E-mail ─────────────────────────────────────────────────────────
IMAP_USER=your-email@plannera.com.br
IMAP_PASSWORD=your-app-password
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_FOLDER=Helpdesk

# ── Integração Slack (F1-16: Escalamento SLA) ──────────────────────────────────
# Webhook para notificações de SLA crítico
SLACK_WEBHOOK_SLA_ALERTS=https://hooks.slack.com/services/T.../B.../XXXX

# ── URL Pública da Aplicação (para links em mensagens) ────────────────────────
# Também usada como base do redirect_uri do OAuth do Read.ai. Deve bater com o domínio real.
NEXT_PUBLIC_APP_URL=https://csplataform.plannera.com

# ── Integração Read.ai (reuniões → timeline/esforço/RAG) ──────────────────────
# NÃO há nada de Read.ai em env: TODA a configuração fica no banco, pela tela
# Configurações → Read.ai (webhooks/signing key, CSM padrão, conta padrão, audience
# e overrides avançados de OAuth/REST). Dois caminhos:
#  1) Webhooks (PUSH, recomendado): configure em app.read.ai/analytics/integrations/webhooks,
#     cole a URL /api/integrations/readai/webhook e a signing key no admin.
#  2) OAuth (PULL, opcional): cada CSM conecta em /home; client auto-registrado (dynamic
#     client registration) ou informado no admin. Authorization server real = authn.read.ai.

# ── Integração Microsoft 365 / Calendário ─────────────────────────────────────
# NÃO há nada de Microsoft em env: as credenciais do app Azure AD (Client ID, Client
# Secret, Tenant ID) ficam no banco, pela tela Configurações → Calendário (Microsoft).
# O redirect_uri é derivado de NEXT_PUBLIC_APP_URL / origem do request (registre-o no
# Azure → Authentication). Permissão necessária no app: Calendars.Read.
# Alternativa sem Azure/admin: cada CSM cola o link .ics publicado do Outlook no widget
# da home (caminho ICS) — também sem env.
