# ==============================================================================
# CS-CONTINUUM — ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# INSTRUCOES:
#   1. Copie este arquivo para .env
#   2. Substitua cada placeholder pelo valor real da sua chave
#   3. NUNCA commite o arquivo .env real no git
# ==============================================================================

# ── Supabase (Banco Relacional + Auth) ────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# ── Google Gemini API (Principal) ─────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Configurações de Modelos (Modo Estabilizado)
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-pro-latest
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_EMBEDDING_DIMENSIONS=768

# ── LLM Gateway (Configuração de Roteamento) ──────────────────────────────────
# Atualmente configurado para modo 'gemini' exclusivo para estabilização
LLM_PROVIDER=gemini
LLM_TIMEOUT_MS=120000
LLM_ALLOW_FALLBACK=false
LLM_FALLBACK_PROVIDER=none

# ── Anthropic Claude (Fallback Futuro) ────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_MAX_TOKENS=1024

# ── Ollama (Local — Fallback Futuro) ──────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Configurações de Negócio / RAG ─────────────────────────────────────────────
CHUNK_SIZE=4000
CHUNK_OVERLAP=500
VECTOR_TOP_K=15
SENTIMENT_ALERT_THRESHOLD=-0.4
COST_TO_SERVE_WARN=0.15
COST_TO_SERVE_CRITICAL=0.30

# ── Integrações (Opcional) ────────────────────────────────────────────────────
AIRTABLE_TOKEN=your-airtable-token
API_SECRET=your-internal-api-secret
SYNC_INTERVAL_MINUTES=5

# ── Suporte / E-mail ─────────────────────────────────────────────────────────
IMAP_USER=your-email@plannera.com.br
IMAP_PASSWORD=your-app-password
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_FOLDER=Helpdesk
